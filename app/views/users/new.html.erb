<%= form_with model: @user, url: signup_path do |f| %>
  <div class="mb-4">
    <%= f.label :name, "ユーザー名", class: "block text-gray-700 text-sm font-bold mb-2" %>
    <%= f.text_field :name, placeholder: "田中太郎", autofocus: true, autocomplete: "name", class: "shadow appearance-none border rounded w-full py-2 px-3 text-gray-700 leading-tight focus:outline-none focus:shadow-outline" %>
  </div>
  <div class="mb-4">
    <%= f.label :email, "メールアドレス", class: "block text-gray-700 text-sm font-bold mb-2" %>
    <%= f.email_field :email, placeholder: "aaaa@example.com", autofocus: true, autocomplete: "email", class: "shadow appearance-none border rounded w-full py-2 px-3 text-gray-700 leading-tight focus:outline-none focus:shadow-outline" %>
  </div>
  <div class="mb-4">
    <%= f.label :password, "パスワード", class: "block text-gray-700 text-sm font-bold mb-2" %>
    <%= f.password_field :password, placeholder: "password", autocomplete: "new-password", class: "shadow appearance-none border rounded w-full py-2 px-3 text-gray-700 leading-tight focus:outline-none focus:shadow-outline" %>
  </div>
  <div class="mb-4">
    <%= f.label :password_confirmation, "パスワード（確認）", class: "block text-gray-700 text-sm font-bold mb-2" %>
    <%= f.password_field :password_confirmation, placeholder: "password", autocomplete: "new-password", class: "shadow appearance-none border rounded w-full py-2 px-3 text-gray-700 leading-tight focus:outline-none focus:shadow-outline" %>
  </div>
  <%= f.submit "サインアップ", class: "bg-blue-500 hover:bg-blue-700 text-white font-bold py-2 px-4 rounded" %>
<% end %>